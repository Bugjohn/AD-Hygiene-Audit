{
  "audit": {
    "inactiveDays": 90,
    "mode": "Full",
    "useMockData": false,
    "outputPath": "./outputs"
  },
  "activeDirectory": {
    "domain": "example.local",
    "credentialFile": "./config/ad-credential.xml",
    "searchBase": "DC=example,DC=local",
    "userSearchBase": "OU=Users,DC=example,DC=local",
    "computerSearchBase": "OU=Computers,DC=example,DC=local",
    "groupSearchBase": "OU=Groups,DC=example,DC=local"
  },
  "privilegedGroups": [
    "Domain Admins",
    "Enterprise Admins",
    "Administrators"
  ],
  "checks": {
    "users": {
      "inactiveUsers": true,
      "passwordNeverExpires": true,
      "adminUsers": true
    },
    "privilegedGroups": {
      "members": true,
      "inactiveMembers": true,
      "accountCompliance": true
    },
    "computers": {
      "inactiveComputers": true,
      "obsoleteOperatingSystems": true
    },
    "domain": {
      "passwordPolicy": true,
      "passwordPolicyAdvanced": true,
      "kerberosPolicyExposure": true
    }
  },
  "reports": {
    "json": true,
    "csv": true,
    "html": false,
    "markdown": false
  }
}
