{
  "audit": {
    "inactiveDays": 90,
    "mode": "Full",
    "useMockData": false,
    "outputPath": "./outputs"
  },
  "activeDirectory": {
    "domain": "example.local",
    "credentialFile": "./config/ad-credential.xml",
    "searchBase": "DC=example,DC=local",
    "userSearchBase": "OU=Users,DC=example,DC=local",
    "computerSearchBase": "OU=Computers,DC=example,DC=local",
    "groupSearchBase": "OU=Groups,DC=example,DC=local"
  },
  "privilegedGroups": [
    "Domain Admins",
    "Enterprise Admins",
    "Administrators"
  ],
  "checks": {
    "users": {
      "inactiveUsers": true,
      "passwordNeverExpires": true,
      "adminUsers": true
    },
    "privilegedGroups": {
      "members": true,
      "inactiveMembers": true,
      "accountCompliance": true,
      "nestedGroups": false
    },
    "computers": {
      "inactiveComputers": true,
      "obsoleteOperatingSystems": true
    },
    "domain": {
      "passwordPolicy": true,
      "passwordPolicyAdvanced": true,
      "kerberosPolicyExposure": true,
      "lockoutPolicy": false,
      "functionalLevel": false
    },
    "kerberos": {
      "serviceAccountsWithSpn": false,
      "unconstrainedDelegation": false
    }
  },
  "severity": {
    "AD-USR-001": "Medium",
    "AD-USR-002": "High",
    "AD-USR-003": "High",
    "AD-PRIV-001": "Info",
    "AD-PRIV-002": "High",
    "AD-PRIV-003": "High",
    "AD-DOM-001": "Info",
    "AD-DOM-002": "Medium",
    "AD-DOM-003": "High",
    "AD-COMP-001": "Medium",
    "AD-COMP-002": "High"
  },
  "reports": {
    "json": true,
    "csv": true,
    "html": false,
    "markdown": false
  },
  "scoring": {
    "enabled": true,
    "levels": {
      "A": "Très bon niveau d’hygiène",
      "B": "Bon niveau d’hygiène",
      "C": "Niveau moyen",
      "D": "Niveau faible",
      "E": "Niveau critique"
    }
  }
}
